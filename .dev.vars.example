# Wrangler reads these when running `npm run preview` (Cloudflare runtime).
# Copy this file to .dev.vars and fill in your values.
# DO NOT commit .dev.vars. It's in .gitignore.
#
# Keep this in sync with .env. The values should be the same; the difference
# is just which dev server reads them.
#
# For production, set these in the Cloudflare dashboard:
#   - NEXT_PUBLIC_* vars  -> BUILD environment AND Runtime (both!)
#   - Server-only secrets -> Runtime only
# See README.md "Cloudflare deployment — required environment setup".

# CMS - public, inlined into client bundle at build time
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# CMS - server-only secrets (Runtime env only on Cloudflare)
# SANITY_API_TOKEN=
# SANITY_WEBHOOK_SECRET=

# Payload - URL is public; required at BUILD env on Cloudflare
# (generateStaticParams runs against it at build time).
# PAYLOAD_API_URL=
# Payload - server-only secrets (Runtime env only)
# PAYLOAD_API_KEY=
# PAYLOAD_WEBHOOK_SECRET=

# R2_PUBLIC_URL=
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# SENTRY_DSN=
