# Next.js dev server (npm run dev) reads these.
# Copy this file to .env and fill in your values.
# DO NOT commit .env. It's in .gitignore.
#
# IMPORTANT: For the Cloudflare runtime preview (npm run preview), Wrangler
# reads .dev.vars instead. Copy the same values to .dev.vars too.
#
# For production on Cloudflare, see the table in README.md
# ("Cloudflare deployment — required environment setup"). NEXT_PUBLIC_* vars
# MUST be set in the BUILD environment (not just Runtime) or builds will
# silently fall back, SSG routes will turn Dynamic, and the site will hit
# Cloudflare 1102 under traffic.

# ============================================================================
# CMS - pick one based on what you set up
# ============================================================================

# --- If using Sanity ---
# These three are PUBLIC (inlined into the client bundle by Next.js at build
# time). They are NOT secrets. They must ALSO be hardcoded as fallbacks in
# src/lib/sanity.ts (using the real values, never 'placeholder') so a missing
# CI Build env var produces a working site, not a silent SSG -> Dynamic
# regression. See CLAUDE.md guardrails 1 and 2.
# Find these at sanity.io/manage > your project > API.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Server-only secrets. Never prefixed with NEXT_PUBLIC_. Set in Runtime env
# only on Cloudflare (not Build).
# Token for fetching unpublished drafts:
# SANITY_API_TOKEN=
# Webhook secret for revalidation endpoint:
# SANITY_WEBHOOK_SECRET=

# --- If using Payload ---
# Your Railway-hosted Payload URL (public — safe in Build env)
# PAYLOAD_API_URL=https://your-cms.up.railway.app
# Server-only API key for protected endpoints (Runtime only)
# PAYLOAD_API_KEY=

# ============================================================================
# Optional: R2 for media CDN (only if using Part 12 of the build guide)
# ============================================================================
# R2_PUBLIC_URL=https://media.yourdomain.com

# ============================================================================
# Optional: Analytics / Monitoring
# ============================================================================
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com
# SENTRY_DSN=
